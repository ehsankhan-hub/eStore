# Environment variables for Docker services
# Copy this file to .env and customize as needed

# MySQL Database Configuration
MYSQL_ROOT_PASSWORD=estore_root_password
MYSQL_DATABASE=estore1
MYSQL_USER=estore_user
MYSQL_PASSWORD=estore_password

# Application Database Connection
DB_HOST=mysql
DB_USER=estore_user
DB_PASSWORD=estore_password
DB_NAME=estore1
DB_PORT=3306

# Port Configuration
MYSQL_PORT=3306
PHPMYADMIN_PORT=8080
APP_PORT=5001

# Docker Configuration
COMPOSE_PROJECT_NAME=estore
COMPOSE_FILE=docker-compose.yml

# Node.js Environment
NODE_ENV=development
JWT_SECRET=estore-secret-key

# Optional: Custom MySQL Configuration
# MYSQL_CHARSET=utf8mb4
# MYSQL_COLLATION=utf8mb4_unicode_ci
